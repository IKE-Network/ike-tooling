<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0
          http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <!--
        Produces the ike-build-standards cascade zip (#402) — the
        declarative cross-repo release ordering consumed by
        ike:release-{draft,publish} and the ws:release-* family.

        The zip unpacks to a flat tree with a single entry:

            release-cascade.yaml

        The manifest's standards-version is filtered so
        "${project.version}" lands as the concrete artifact version,
        mirroring the scaffold manifest. ike-maven-plugin and
        ike-workspace-maven-plugin resolve this classified artifact
        at release time rather than relying on a lifecycle-bound
        unpack, because the release goals are standalone aggregators.
    -->
    <id>cascade</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>src/main/cascade</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>release-cascade.yaml</include>
            </includes>
            <filtered>true</filtered>
        </fileSet>
    </fileSets>
</assembly>
