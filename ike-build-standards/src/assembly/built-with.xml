<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0
          http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <!--
        Platform-wide built-with supplement (#340). Ships
        src/main/built-with/supplement.yaml as a classified ZIP so
        external consumers (ike-lab-documents, doc-example,
        project-example, etc.) get curated narrative on their
        built-with.html page without authoring their own supplement.
        Unpacked at pre-site phase by maven-dependency-plugin's
        unpack-built-with-supplement execution into
        target/built-with-supplement.yaml; ike:built-with reads it as
        a fallback when no on-disk supplement is found via walk-up.
    -->
    <id>built-with</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>src/main/built-with</directory>
            <outputDirectory>/</outputDirectory>
            <useDefaultExcludes>false</useDefaultExcludes>
            <includes>
                <include>supplement.yaml</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
