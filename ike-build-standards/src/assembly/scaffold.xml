<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0
          http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <!--
        Produces the ike-build-standards scaffold zip consumed by
        the ike:scaffold-* goal family (#221, #222).

        The zip unpacks to a flat tree rooted at scaffold-manifest.yaml:

            scaffold-manifest.yaml
            tool-owned/hooks/{pre-commit,post-commit,pre-push}
            tracked/{maven.config,gitignore.ike-block}

        The manifest is filtered so "${project.version}" lands as the
        concrete artifact version, keeping the lockfile in sync with
        the shipped standards.
    -->
    <id>scaffold</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <!-- scaffold-manifest.yaml is filtered for ${project.version}. -->
        <fileSet>
            <directory>src/main/scaffold</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>scaffold-manifest.yaml</include>
            </includes>
            <filtered>true</filtered>
        </fileSet>
        <!-- Everything else ships verbatim. -->
        <fileSet>
            <directory>src/main/scaffold</directory>
            <outputDirectory>/</outputDirectory>
            <excludes>
                <exclude>scaffold-manifest.yaml</exclude>
            </excludes>
            <fileMode>0755</fileMode>
        </fileSet>
    </fileSets>
</assembly>
